###############################################################################
#  приведено в качестве примера, реальные пароли тут не раскрываются
###############################################################################

# ── PostgreSQL credentials ──────────────────────────────────────────────────
# Production: придумать сильные пароли (20+ символов), сохранить в менеджере.
POSTGRES_USER=counterfeit
POSTGRES_PASSWORD=CHANGE_ME_strong_password_123
POSTGRES_DB=counterfeit

# ── RabbitMQ credentials ────────────────────────────────────────────────────
RABBITMQ_USER=counterfeit
RABBITMQ_PASSWORD=CHANGE_ME_another_strong_password_456

# ── Port bindings (production: только 127.0.0.1, проксируется через nginx) ──
# Локально для дебага можно открыть наружу — заменить на 0.0.0.0:PORT.
# На Timeweb VPS оставляем 127.0.0.1, чтобы Postgres/RabbitMQ были недоступны
# из внешнего интернета напрямую.
API_BIND=127.0.0.1:8000
POSTGRES_BIND=127.0.0.1:5432
RABBITMQ_AMQP_BIND=127.0.0.1:5672
RABBITMQ_UI_BIND=127.0.0.1:15672

# ── CORS allow_origins ──────────────────────────────────────────────────────
# Через запятую. На production — реальный публичный URL вашего фронта.
CORS_ALLOWED_ORIGINS=https://your-domain.timeweb.cloud,http://localhost:8000

# ── Resource limits (Docker) ────────────────────────────────────────────────
# Подобрать под VPS. На 4 ГБ RAM Timeweb-инстансе:
#   API   ~ 1.5g (CatBoost + CLIP)
#   Worker ~ 1.5g
# При включении LLM (USE_LLM_REASONING=1) — увеличить на +3g на 1.5B-модель.
API_MEMORY_LIMIT=2g
WORKER_MEMORY_LIMIT=2g

# ── Predictor / Reasoning channel (§ 4.4.9.7) ───────────────────────────────
PREDICTOR_TYPE=reasoning_pipeline
PREDICTOR_INNER=d2v_catboost
# 0 = template-based explainer (быстро, детерминированно — рекомендовано для CPU)
# 1 = LLM-канал (Qwen2.5, нужно много RAM, лучше с GPU)
USE_LLM_REASONING=0
# Параметры LLM-канала (используются только если USE_LLM_REASONING=1)
LLM_REASONING_MODEL=Qwen/Qwen2.5-1.5B-Instruct
LLM_REASONING_DEVICE=cpu  # cpu | cuda | mps
LLM_REASONING_MAX_TOKENS=260
# (опционально) — авторизованная загрузка моделей с HuggingFace, ускоряет первый старт.
HF_TOKEN=

# ── Worker settings ─────────────────────────────────────────────────────────
WORKER_PREFETCH=1
COUNTERFEIT_THRESHOLD=0.5
